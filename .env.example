# Block Maps environment variables
# Copy to .env.local and fill in. Never commit your filled .env.local.

# Postgres connection string. Block Maps is built against Neon Postgres
# (https://neon.tech) but any Postgres 14+ instance works for the catalog
# tables. The schema lives in lib/db/schema.sql; apply it with:
#
#   bun run db:migrate
#
# Format: postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
DATABASE_URL=

# OpenRouter credentials for the conversational map agent.
# Get an API key at https://openrouter.ai/keys
# Browse models at https://openrouter.ai/models
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# MTA GTFS-Realtime API key for live subway/bus positions.
# Register (free) at https://api.mta.info/
MTA_API_KEY=
